{
    "version": 2,
    "builds": [
        {
            "src": "bmtc-backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "bmtc-backend/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/verify",
            "dest": "bmtc-backend/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "bmtc-backend/public/$1"
        }
    ]
}